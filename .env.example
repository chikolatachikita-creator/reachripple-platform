# ============ DATABASE ============
MONGO_URI=mongodb://127.0.0.1:27017/reachripple-dev

# ============ SERVER ============
PORT=3001
NODE_ENV=development

# ============ JWT SECRETS (Min 32 chars) ============
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_min_32_chars_long

# ============ CORS ============
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============ EMAIL (Optional - uses console logging if not set) ============
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ============ REDIS (Optional - caching will be disabled if not set) ============
REDIS_URL=redis://127.0.0.1:6379

# ============ AWS S3 (Optional - for file uploads) ============
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ============ OPENAI (For AI features) ============
OPENAI_API_KEY=your_openai_api_key

# ============ ENVIRONMENT FLAGS ============
DEBUG=false
ALLOW_MOCK_DATA=true
