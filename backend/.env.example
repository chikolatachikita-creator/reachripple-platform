# Copy this file to .env and fill the secrets before running the server
# ============ DATABASE ============
# MongoDB connection string. When using docker-compose, the container
# exposes port 27017 on localhost so this value works with `docker compose up -d`.
MONGO_URI=mongodb://127.0.0.1:27017/reachripple-dev

# ============ REDIS ============
# Redis connection (optional — app works without it but caching is disabled)
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_PASSWORD=

# ============ SERVER ============
PORT=3001
# NODE_ENV=development

# ============ JWT ============
# Replace with strong, random strings in production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET

# ============ CORS ============
FRONTEND_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000

# ============ EMAIL (SMTP) ============
# Optional — emails are logged to console when not configured
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@reachripple.com

# ============ AI (Optional) ============
# Used for AI-generated ad descriptions
# OPENAI_API_KEY=sk-...

# ============ OAUTH (Optional) ============
# Google OAuth — get credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# GitHub OAuth — get credentials at https://github.com/settings/developers
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
