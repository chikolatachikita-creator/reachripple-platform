# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!

# ============ DATABASE ============
# MongoDB Atlas example: mongodb+srv://username:password@cluster.mongodb.net/reachripple-prod
# Local example: mongodb://username:password@localhost:27017/reachripple-prod
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/reachripple-prod?retryWrites=true&w=majority

# ============ SERVER ============
PORT=3001
NODE_ENV=production

# ============ JWT SECRETS ============
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANT: Keep these secret and never share them!
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ============ CORS (Frontend Domain) ============
# Set to your production frontend domain
# Examples:
#   Single domain: https://www.yoursite.com
#   Multiple domains: https://www.yoursite.com,https://app.yoursite.com
CORS_ORIGIN=https://www.yoursite.com
FRONTEND_URL=https://www.yoursite.com

# ============ SSL/HTTPS (Optional) ============
# Only needed if using Node.js HTTPS instead of reverse proxy
# SSL_KEY=/path/to/privkey.pem
# SSL_CERT=/path/to/fullchain.pem

# ============ EMAIL (SMTP) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@reachripple.com

# ============ REDIS ============
REDIS_URL=redis://:password@redis:6379
REDIS_PASSWORD=your-redis-password

# ============ AI (Optional) ============
# OPENAI_API_KEY=sk-...

# ============ OAUTH (Optional) ============
# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://www.yoursite.com/auth/google/callback

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ============ SECURITY ============
# These are already configured in code, but can override if needed
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
