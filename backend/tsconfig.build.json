{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": false,
    "declaration": false
  },
  "include": [
    "*.ts",
    "controllers/**/*",
    "models/**/*",
    "routes/**/*",
    "middleware/**/*",
    "services/**/*",
    "validators/**/*",
    "config/**/*",
    "utils/**/*",
    "constants/**/*",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/**/*",
    "scripts/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/future/**",
    "**/*.bak/**"
  ]
}
